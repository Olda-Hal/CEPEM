# CEPEM Environment Variables Template
# Copy this file to .env and update the values as needed

# Version Information
CEPEM_VERSION=0.1.2
CEPEM_BUILD_NUMBER=2
CEPEM_BUILD_DATE=2025-09-30T15:45:58Z

# ============================================================================
# APPLICATION HOST CONFIGURATION
# Change APP_HOST here and everything else configures automatically
# Examples: localhost, example.com, api.myapp.com, etc.
# ============================================================================
APP_HOST=localhost

# ============================================================================
# MySQL Database Configuration
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=cepem_healthcare
MYSQL_USER=cepem_user
MYSQL_PASSWORD=cepem_password
MYSQL_PORT=3306

# ASP.NET Core Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS_HEALTHCARE=http://+:80
ASPNETCORE_URLS_DATABASE=http://+:5001

# Connection Strings
HEALTHCARE_API_CONNECTION_STRING=Server=mysql;Database=cepem_healthcare;Uid=cepem_user;Pwd=cepem_password;
DATABASE_API_CONNECTION_STRING=Server=mysql;Database=cepem_healthcare;User=root;Password=rootpassword;

# JWT Configuration
# IMPORTANT: Change these values in production!
JWT_SECRET_KEY=CEPEMHealthcareSecretKey2024ForJWTTokens!
JWT_ISSUER=CEPEM-Healthcare
JWT_AUDIENCE=CEPEM-Doctors

# Ports (Internal container ports)
HEALTHCARE_API_PORT=5000
DATABASE_API_PORT=5001
AI_SERVICE_PORT=8000
FRONTEND_PORT=3000

# API URLs (Derived from APP_HOST above)
# Change APP_HOST instead of editing these
DATABASE_API_URL=http://database-api:5001
REACT_APP_API_URL=http://${APP_HOST}:5000
REACT_APP_AI_API_URL=http://${APP_HOST}:8000

# Encryption Configuration
# IMPORTANT: Change these values in production!
PHOTO_ENCRYPTION_KEY=CEPEMSecureKey1234567890123456
PHOTO_ENCRYPTION_IV=CEPEMInitVector1
DOCUMENT_ENCRYPTION_KEY=CEPEMSecureKey1234567890123456
DOCUMENT_ENCRYPTION_IV=CEPEMInitVector1

# Storage Paths
PHOTO_STORAGE_PATH=/app/patient-photos
DOCUMENT_STORAGE_PATH=/app/patient-documents

# CORS Configuration (Auto-generated from APP_HOST)
# These are automatically constructed - change APP_HOST to update all CORS origins
CORS_ORIGINS=http://${APP_HOST}:3000,http://frontend:3000
HEALTHCARE_API_CORS_ORIGINS=http://${APP_HOST}:3000,http://frontend:3000
DATABASE_CORS_ORIGINS=http://${APP_HOST}:3000,http://frontend:3000

# Production Notes:
# - MySQL container will be available in production via docker-compose
# - Local volumes are used for patient photos and documents
# - Connection strings use container name 'mysql' for internal communication

# Grafana Configuration (disabled)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GRAFANA_PORT=3001
